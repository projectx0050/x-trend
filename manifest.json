{
  "manifest_version": 3,
  "name": "X-Trend",
  "version": "1.0.1",
  "description": "AI-powered writing assistant for social media content creators",
  "action": {
    "default_popup": "popup.html",
    "default_title": "X-Trend",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://x-trend-backend.onrender.com/*"
  ]
}
